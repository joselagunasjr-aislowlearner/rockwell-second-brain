{
  "name": "@rockwell/scripts",
  "version": "1.0.0",
  "description": "Sync scripts for Google Drive and Gmail integration",
  "type": "module",
  "scripts": {
    "sync": "tsx src/sync.ts",
    "sync:drive-only": "tsx src/sync.ts --drive-only",
    "sync:gmail-only": "tsx src/sync.ts --gmail-only",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/?(*.)+(spec|test).ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@supabase/supabase-js": "^2.43.0",
    "googleapis": "^142.0.0",
    "google-auth-library": "^9.6.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0"
  }
}
