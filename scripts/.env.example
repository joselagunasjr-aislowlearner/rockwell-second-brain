# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Google OAuth 2.0 (Desktop app credentials from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Sync configuration
DRIVE_SEARCH_KEYWORDS=SOP,operations,audit,vendor,guidebook
GMAIL_SEARCH_QUERY=from:vendor@example.com OR subject:agreement
